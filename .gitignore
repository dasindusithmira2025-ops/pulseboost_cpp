# Gitignore for PulseBoost

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Application data
data/
*.db
*.db-shm
*.db-wal
*.log
*.sqlite
*.sqlite3

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# Build outputs
pulseboost/ui/dist/
pulseboost/ui/.vite/
pulseboost/ui/coverage/

# Temporary files
.archive/
*.tmp
*.temp
*.bak
*.orig

# Secrets
.env
.env.*
!.env.example
*.key
*.pem
credentials.json

# Runtime
pulseboost/run/*.log
pulseboost/data/

# Local bundled runtimes and dependency caches
pulseboost/tools/
!pulseboost/tools/.gitkeep

# Generated local exports
*.zip
*.7z
*.rar
*.exe
*.msi
