{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "PulseBoost AI",
    "version": "1.0.0"
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run build",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": false,
        "minimize": true,
        "maximize": true,
        "close": true
      }
    },
    "windows": [
      {
        "title": "PulseBoost AI",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
